{
  "name": "neoclaw",
  "description": "NeoClaw — a super AI assistant",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "onboard": "bun run src/index.ts onboard",
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "typecheck": "bun run --bun tsc --noEmit",
    "lint": "vp lint src/"
  },
  "bin": {
    "neoclaw": "./src/index.ts"
  },
  "dependencies": {
    "@neoclaw/core": "workspace:*",
    "@neoclaw/agents": "workspace:*",
    "@neoclaw/gateway": "workspace:*",
    "@neoclaw/cron": "workspace:*",
    "@clack/prompts": "^1.1.0",
    "citty": "^0.2.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "vite-plus": "latest"
  }
}
